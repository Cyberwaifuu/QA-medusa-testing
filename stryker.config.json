{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.json",
  "mutate": [
    "src/modules/cart-service.ts",
    "src/modules/inventory-manager.ts",
    "src/modules/payment-processor.ts",
    "src/modules/checkout-validator.ts",
    "src/modules/order-service.ts",
    "src/validators.ts",
    "!src/**/*.test.ts"
  ],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation-report.json"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "concurrency": 2,
  "timeoutMS": 30000
}