{
  "name": "medusa-qa-testing",
  "version": "1.0.0",
  "description": "QA Testing Framework for Medusa E-Commerce Platform",
  "scripts": {
    "test:e2e": "npx playwright test",
    "test:api": "npx newman run tests/api/medusa-api.postman_collection.json",
    "test:unit": "npx vitest run",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "test:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "newman": "^6.2.2",
    "vitest": "^3.2.4"
  }
}
