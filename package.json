{
  "name": "medusa-qa-testing",
  "version": "1.0.0",
  "description": "QA Testing Framework for Medusa E-Commerce Platform",
  "scripts": {
    "test:unit": "vitest run tests/unit/",
    "test:api": "vitest run tests/api/",
    "test:e2e": "npx playwright test",
    "test:all:local": "npm run test:unit && npm run test:api && npm run test:e2e",
    "allure:clean": "rimraf allure-results allure-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.2.4",
    "allure-playwright": "^3.7.1",
    "allure-vitest": "^3.7.1",
    "axios": "^1.15.1",
    "newman": "^6.2.2",
    "rimraf": "^6.1.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
